[Unit]
Description=Mood Plotter PIR Watcher
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/mood-plotter/pi
EnvironmentFile=/home/pi/mood-plotter/.env
# System-python (inte venv) for gpiozero+lgpio — Pi OS-paket ar precompilerade.
ExecStart=/usr/bin/python3 pir_watcher.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
