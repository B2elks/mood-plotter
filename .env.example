# 46elks
ELKS_API_USERNAME=
ELKS_API_PASSWORD=
ELKS_FROM_NUMBER=+46xxxxxxxxx
USER_PHONE_NUMBER=+46xxxxxxxxx

# OpenAI
OPENAI_API_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Server
SERVER_PUBLIC_URL=https://moodplotter.skyttberg.nu
PI_TOKEN=changeme-shared-secret
ADMIN_PASSWORD=changeme-admin-pass
COOLDOWN_SECONDS=300
DRY_RUN=false
# Sätt true när ingen AxiDraw är ansluten (server-only-mode med galleri)
ALLOW_NO_PLOTTER=false
# 46elks WS-nummer som routar samtalet till /ws-voice. Konfigureras med
# 46elks-API:t (nummerets ws_url ska peka pa ws://skyttberg.nu:8121/ws-voice).
WS_CONNECT_NUMBER=+4600700020
WS_VOICE_PORT=8121

# Pi
SERVER_URL=https://moodplotter.skyttberg.nu
SERVER_WS_URL=wss://moodplotter.skyttberg.nu/ws
PI_ID=desk1
PIR_GPIO_PIN=4
PIR_DEBOUNCE_SECONDS=30
